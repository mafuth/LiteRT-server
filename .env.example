# Application
APP_TITLE="Edge AI API"
APP_DESCRIPTION="Running an Open AI API compatible server for LiteRT-LM."
APP_VERSION="0.0.1"
APP_ENV="production"           # set to "dev" to enable file logging

# LLM Model
LLM_MODEL="gemma-4-4B-it"     # filename without .litertlm extension, placed in models/
LLM_BACKEND="CPU"              # CPU or GPU
LLM_AUDIO_BACKEND="CPU"        # CPU or GPU
LLM_VISION_BACKEND="CPU"       # CPU or GPU

# Server
UVICORN_HOST="0.0.0.0"
UVICORN_PORT="8000"
UVICORN_WORKERS="1"            # keep at 1 - multiple workers each load a full model copy
UVICORN_RELOAD="false"         # never combine with UVICORN_WORKERS > 1
UVICORN_LOOP="asyncio"
UVICORN_HTTP="httptools"
UVICORN_ACCESS_LOG="false"

# CORS
# WARNING: setting CORS_ALLOW_CREDENTIALS=true requires CORS_ALLOW_ORIGINS to be
# explicit origins (e.g. "http://localhost:3000"), not "*".
CORS_ALLOW_ORIGINS="*"
CORS_ALLOW_CREDENTIALS="false"
CORS_ALLOW_METHODS="*"
CORS_ALLOW_HEADERS="*"

# Logging (only used when APP_ENV=dev)
LOG_LEVEL="INFO"
LOG_FILE_PATH="logs/app.log"
LOG_ROTATION_WHEN="midnight"
LOG_ROTATION_INTERVAL="1"
LOG_BACKUP_COUNT="3"

# Open WebUI (used by docker-compose.yml)
WEBUI_SECRET_KEY="change-me-to-a-random-secret"
