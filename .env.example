# Model Repository (Hugging Face)
# Example: litert-community/gemma-4-E2B-it-litert-lm
MODEL_REPO=litert-community/gemma-4-E4B-it-litert-lm

# Model Filename in the repo
MODEL_FILENAME=gemma-4-E4B-it.litertlm

# Optional: HuggingFace API token (required for gated/private repos)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Local directory to store models
MODELS_DIR=models

# Execution device: CPU or GPU
DEVICE=CPU

# API Settings
PORT=8000
HOST=0.0.0.0
